# Nivas Staff Mobile App Environment
# Copy to .env and fill in your values

# API URL for your backend
# Physical device on same Wi‑Fi — use your PC's LAN IP (NOT localhost):
#   ipconfig  →  IPv4 Address, e.g. http://192.168.1.100:3000
# Android emulator — use the host loopback alias:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# iOS simulator — localhost works:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# MinIO / menu images — same LAN IP as API, port 9000 (must match docker-compose minio bind)
# EXPO_PUBLIC_STORAGE_URL=http://192.168.1.100:9000

# WebSocket URL (optional, defaults to ws://localhost:3000)
# Production: wss://api.yourdomain.com
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# ── Optional / Production ──
# Sentry DSN for crash reporting (production only)
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
