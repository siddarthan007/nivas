{
  "expo": {
    "name": "Nivas",
    "slug": "nivas",
    "version": "1.0.0",
    "scheme": "nivas",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1a365d",
    "splash": {
      "backgroundColor": "#1a365d"
    },
    "extra": {
      "eas": {
        "projectId": "909cd8b9-73ab-492d-b9e4-ea264df017a5"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/909cd8b9-73ab-492d-b9e4-ea264df017a5",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nivas.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:nivas.app"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.nivas.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "nivas",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#1a365d",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
