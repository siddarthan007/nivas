# ============================================================
# Nivas PMS Frontend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Backend API URL ──────────────────────────────────────────
# Docker: use service name "backend"
BACKEND_URL=http://backend:3000

# Local dev (non-docker):
# BACKEND_URL=http://localhost:3000

# ── Client-side API path (relative — goes through proxy) ─────
BASE_API_URL=/api/v1
