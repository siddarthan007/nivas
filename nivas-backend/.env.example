# ============================================================
# Nivas PMS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────
# Docker: use service name "postgres" as host
DATABASE_URL=postgres://postgres:changeme@postgres:5432/nivas_db
# Local dev (non-docker):
# DATABASE_URL=postgres://postgres:changeme@localhost:5432/nivas_db
# Connection pool (PER INSTANCE — keep modest so N replicas don't exhaust Postgres).
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=15

# ── Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-char-secret-minimum
JWT_EXPIRY=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Storage (MinIO) ─────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=nivas_minio
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET=nivas
# Public, browser-reachable storage URL. REQUIRED in production so uploaded images
# and backup links resolve from outside the network. With the bundled MinIO +
# nginx /storage/ proxy, set this to your domain + /storage:
MINIO_PUBLIC_URL=https://yourdomain.com/storage
# For local non-Docker dev, point to localhost:
# MINIO_ENDPOINT=localhost

# ── Database Backups ─────────────────────────────────────────
# Private bucket for compressed DB backups (separate from public assets).
MINIO_BACKUP_BUCKET=nivas-backups
# How many backups to retain (older ones auto-deleted).
BACKUP_KEEP=3
# Temp dir for streaming pg_dump to disk before upload (defaults to OS temp).
# BACKUP_TMP_DIR=/tmp

# ── AI Engine (optional — Gemini Flash) ──────────────────────
# Platform-wide fallback key used when a hotel has not set its own. Leave blank to
# require each hotel to bring its own key in Settings → AI.
AI_API_KEY=
# The AI MODEL is chosen per hotel in Settings → AI (no env needed).
# Override only the provider endpoint if not using Google Gemini:
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── IRD CBMS (Nepal e-billing — optional, plan-gated) ────────
# Official IRD Central Billing Monitoring System endpoints (rarely change).
CBMS_BILL_URL=https://cbapi.ird.gov.np/api/bill
CBMS_RETURN_URL=https://cbapi.ird.gov.np/api/billreturn

# ── Logging ──────────────────────────────────────────────────
# error | warn | info | debug
LOG_LEVEL=info

# ── Super Admin (first-time seed) ────────────────────────────
SUPER_ADMIN_EMAIL=admin@nivaspms.com
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=9800000000

# ── Guest Portal ─────────────────────────────────────────────
GUEST_PORTAL_URL=http://localhost:5173

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:nivas_redis_dev@redis:6379
# Local dev (non-docker):
# REDIS_URL=redis://localhost:6379
# Optional discrete fields (used only if REDIS_URL is not set):
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=nivas_redis_dev
