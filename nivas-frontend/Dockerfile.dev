# ============================================================
# Nivas PMS Frontend — Development Dockerfile
# Runs Bun server with HMR, source mounted via volume
# ============================================================

FROM oven/bun:1
WORKDIR /usr/src/app

# Install deps first (cached layer)
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy tsconfig so Bun dev server resolves @/* path aliases
COPY tsconfig.json ./

# Source will be mounted as volume at runtime

EXPOSE 5173

CMD ["bun", "--hot", "src/index.ts"]
