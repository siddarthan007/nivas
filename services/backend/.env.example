# ============================================================
# Nivas PMS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Core ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────
# Docker: use service name "postgres" as host
DATABASE_URL=postgres://postgres:changeme@postgres:5432/nivas_db
# Production with PgBouncer (docker-compose.prod.yml): app → pooler, DDL/backups → Postgres.
# DATABASE_URL=postgres://postgres:changeme@pgbouncer:5432/nivas_db
# DATABASE_DIRECT_URL=postgres://postgres:changeme@postgres:5432/nivas_db
# Local dev (non-docker):
# DATABASE_URL=postgres://postgres:changeme@localhost:5432/nivas_db
# Connection pool (PER INSTANCE — keep modest so N replicas don't exhaust Postgres).
# Single-node prod: 8. Three replicas: 6 each + PgBouncer recommended.
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=15

# ── Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-char-secret-minimum
JWT_EXPIRY=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (browser / Expo web).
# Mobile native app does not use CORS; LAN API access is controlled by Docker port bind + firewall.
# Add your PC LAN IP when testing web or Expo from a phone, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.100:3000,http://192.168.1.100:8081,exp://*
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,exp://*

# ── File Storage (MinIO) ─────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=nivas_minio
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET=nivas
# Days before an unreferenced upload is eligible for orphan cleanup (weekly job).
MINIO_ORPHAN_MIN_AGE_DAYS=7
# Public, browser-reachable storage URL. REQUIRED in production so uploaded images
# and backup links resolve from outside the network. With the bundled MinIO +
# nginx /storage/ proxy, set this to your domain + /storage:
MINIO_PUBLIC_URL=https://yourdomain.com/storage
# For local non-Docker dev, point to localhost:
# MINIO_ENDPOINT=localhost

# ── Database Backups ─────────────────────────────────────────
# Private bucket for compressed DB backups (separate from public assets).
MINIO_BACKUP_BUCKET=nivas-backups
# How many backups to retain (older ones auto-deleted).
BACKUP_KEEP=3
# Temp dir for streaming pg_dump to disk before upload (defaults to OS temp).
# BACKUP_TMP_DIR=/tmp

# ── AI Engine (Gemini Flash) ─────────────────────────────────
# Each hotel brings its OWN Gemini API key + model in Settings → General → AI.
# There is no platform/.env key. Only override the provider endpoint if not using
# Google Gemini (rare):
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── IRD CBMS (Nepal e-billing — optional, plan-gated) ────────
# Official IRD Central Billing Monitoring System endpoints (rarely change).
CBMS_BILL_URL=https://cbapi.ird.gov.np/api/bill
CBMS_RETURN_URL=https://cbapi.ird.gov.np/api/billreturn

# ── Logging ──────────────────────────────────────────────────
# error | warn | info | debug — use warn in production to save disk/RAM
LOG_LEVEL=info
# Fraction of requests to log in production (0–1). Health/docs are always skipped.
LOG_SAMPLE_RATE=0.05
# API docs at /docs — off in production unless explicitly enabled
ENABLE_SWAGGER=true

# ── Super Admin (first-time seed) ────────────────────────────
SUPER_ADMIN_EMAIL=admin@nivaspms.com
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=9800000000

# ── Guest Portal ─────────────────────────────────────────────
GUEST_PORTAL_URL=http://localhost:5173

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:nivas_redis_dev@redis:6379
# Local dev (non-docker):
# REDIS_URL=redis://localhost:6379
# Optional discrete fields (used only if REDIS_URL is not set):
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=nivas_redis_dev

# ── Production / Deployment ──────────────────────────────────
# Set to true when running behind a reverse proxy (nginx, Traefik, ALB).
# Affects secure cookie flag and X-Forwarded-For trust.
TRUST_PROXY=false

# Public base URL used in QR codes, email links, and webhooks.
# Must be reachable from the internet. No trailing slash.
API_BASE_URL=https://api.yourdomain.com

# Request timeout in ms (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Max payload size in bytes (default: 10MB)
MAX_BODY_SIZE=10485760

# ── Resource profile (production Docker) ─────────────────────
# See docker-compose.prod.yml — tune via env:
# PG_MEM_LIMIT=768M  REDIS_MEM_LIMIT=640M  BACKEND_MEM_LIMIT=512M
# BACKUP_KEEP=3      LOG_LEVEL=warn        LOG_SAMPLE_RATE=0.05
# ENABLE_SWAGGER=false   DB_POOL_MAX=8
